@page "/evidence"

<PageTitle>Evidence financí</PageTitle>

<div class="row ">
    <div class="col">
        <h3>Evidence nákladů a výnosů</h3>
    </div>

    <div class="col ">
        <button type="button" @onclick="UlozitData" class="btn btn-outline-primary">Uložit</button>
        <button type="button" @onclick="NacistData" class="btn btn-outline-primary">Načíst</button>
        <button type="button" @onclick="SmazatVse" class="btn btn-outline-danger">Smazat vše</button>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <EditForm Model="formularTransakce" OnValidSubmit="UlozitTransakci">
            <DataAnnotationsValidator />

            <div class="row align-items-center">
                <div class="col mb-1 mt-1">
                    <label for="datum" class="form-label">Datum:</label>
                    <InputDate class="form-control" id="datum" @bind-Value="formularTransakce.Datum" placeholder="Vložte datum" />
                    <ValidationMessage For="@(() => formularTransakce.Datum)" />
                </div>

                <div class="col mb-1 mt-1">
                    <label for="vynosy" class="form-label">Výnosy:</label>
                    <InputNumber class="form-control" id="vynosy" @bind-Value="formularTransakce.Vynosy" placeholder="Vložte výnosy" />
                    <ValidationMessage For="@(() => formularTransakce.Vynosy)" />
                </div>

                <div class="col mb-1 mt-1">
                    <label for="naklady" class="form-label">Náklady:</label>
                    <InputNumber class="form-control" id="naklady" @bind-Value="formularTransakce.Naklady" placeholder="Vložte náklady" />
                    <ValidationMessage For="@(() => formularTransakce.Naklady)" />
                </div>

                <div class="col mb-1 mt-1">
                    <label for="popis" class="form-label">Popis:</label>
                    <InputText class="form-control" id="popis" @bind-Value="formularTransakce.Popis" placeholder="Vložte popis" />
                    <ValidationMessage For="@(() => formularTransakce.Popis)" />
                </div>

                <button type="submit" class="col btn btn-primary">
                    @(!JeEditace ? "Přidat záznam" : "Uložit změny")

                </button>
            </div>
            @if (JeEditace)
            {
                <div class="alert alert-warning">
                    <span class="material-symbols-outlined">
                        edit
                    </span>
                    Právě upravujete záznam <strong>@originalEditovaneTransakce?.Datum</strong>
                    <button type="reset" @onclick="ZrusitEditaci" class="btn btn-outline-secondary">Zrušit editaci</button>
                </div>
            }
        </EditForm>
    </div>
</div>

<div class="mt-3 row">
    <div class="col input-group">
        <span class="input-group-text">
            <span class="material-symbols-outlined">
                search
            </span>
        </span>
        <input type="text" 
            @bind="FiltrPopis"
            @bind:event="oninput"
            class="form-control" placeholder="Hledat v popisu">
    </div>
    <div class="col">
        <select class="form-select" @bind="FiltrZiskOperator">
            <option value="@Models.OperatorZisku.Rovno">Zisk rovno (=)</option>
            <option value="@Models.OperatorZisku.VetsiNez">Zisk větší (&gt;)</option>
            <option value="@Models.OperatorZisku.MensiNez">Zisk menší (&lt;)</option>
        </select>
    </div>
  
    <div class="col">
        <input type="number" 
            @bind="FiltrZiskHodnota"
            @bind:event="oninput"
            class="form-control" placeholder="Zadejte hodnotu zisku">
    </div>

    <div class="col">
        <button type="button" @onclick="ZrusitFiltr" class="btn btn-outline-secondary">X</button>
    </div>
</div>

<div class="container mt-3">
    <table class="table">
        <thead class="table-dark">
            <tr>
                <th>Datum</th>
                <th>Popis</th>
                <th>Výnosy</th>
                <th>Náklady</th>
                <th>Zisk</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var itemTransakce in FiltrovaneTransakce)
            {
                var cssClass = itemTransakce.Zisk >= 0 ? "text-success" : "text-danger";
                <tr>
                    <td>@itemTransakce.Datum.ToShortDateString()</td>
                    <td>@itemTransakce.Popis</td>
                    <td class="text-end text-success">@itemTransakce.Vynosy.ToString("N2")</td>
                    <td class="text-end text-danger">@itemTransakce.Naklady.ToString("N2")</td>
                    <td class="text-end @cssClass">@itemTransakce.Zisk.ToString("N2")</td>
                    <td>
                        <button type="button" @onclick="() => EditovatTransakci(itemTransakce)" class="btn btn-outline-primary">
                            <span class="material-symbols-outlined">
                                edit
                            </span>
                            Upravit
                        </button>
                        <button type="button" @onclick="() => SmazatTransakci(itemTransakce)" class="btn btn-outline-danger">
                            <span class="material-symbols-outlined">
                                delete
                            </span>
                            Smazat
                        </button>
                    </td>
                </tr>
            }


        </tbody>
    </table>

</div>

